{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "fs:default",
    "android-fs:all-without-delete",
    {
      "identifier": "fs:allow-download-read-recursive",
      "allow": [
        {
          "path": "$DOWNLOAD/*"
        }
      ]
    },
    {
      "identifier": "fs:allow-download-write-recursive",
      "allow": [
        {
          "path": "$DOWNLOAD/*"
        }
      ]
    },
    {
      "identifier": "fs:allow-picture-read-recursive",
      "allow": [
        {
          "path": "$PICTURE/*"
        }
      ]
    },
    {
      "identifier": "fs:allow-picture-write-recursive",
      "allow": [
        {
          "path": "$PICTURE/*"
        }
      ]
    },
    "os:default"
  ]
}