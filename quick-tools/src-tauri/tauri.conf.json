{
    "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
    "productName": "Quick Tools",
    "version": "1.0.0",
    "identifier": "com.newtun.quicktools",
    "build": {
        "frontendDist": "../dist/quick-tools/browser",
        "devUrl": "http://localhost:4200",
        "beforeDevCommand": "ng s",
        "beforeBuildCommand": "ng build"
    },
    "app": {
        "windows": [
            {
                "label": "main",
                "title": "Quick Tools",
                "width": 800,
                "height": 600,
                "resizable": true,
                "fullscreen": false,
                "center": true
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/64x64.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    }
}
